{
  "name": "devflow",
  "version": "1.0.0",
  "description": "An open-source, agile project management platform with local Git integration.",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"FRONT,BACK\" -c \"cyan,magenta\" \"vite\" \"node --watch server/index.js\"",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ports = @(3000,3001); $connections = Get-NetTCPConnection -State Listen -LocalPort $ports -ErrorAction SilentlyContinue; $usedPorts = @($connections | Select-Object -ExpandProperty LocalPort -Unique | Sort-Object); $pids = @($connections | Select-Object -ExpandProperty OwningProcess -Unique); if ($pids.Count -gt 0) { Stop-Process -Id $pids -Force; Write-Host ('Stopped processes on ports ' + ($usedPorts -join ', ')); } else { Write-Host 'No listening processes found on ports 3000 and 3001.' }\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --fix --report-unused-disable-directives",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.3.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
